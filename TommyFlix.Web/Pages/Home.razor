@page "/"
@inject NavigationManager Navigation


<PageTitle>Home</PageTitle>


<div class="carousel-wrapper">
    <button class="nav-btn left" @onclick="() => Scroll(-1)">&#10094;</button>

    <div class="movie-container" @ref="movieSlider">
        @foreach (var movie in ListaDePeliculas)
        {
            <div class="movie-card" @onclick="() => IrAlDetalle(35)">
                <img src="@movie.PosterUrl" alt="@movie.Titulo" class="movie-poster" />
                <div class="movie-overlay">
                    <h5 class="movie-title">@movie.Titulo</h5>
                    <span class="movie-badge">@movie.Clasificacion</span>
                    <div class="movie-actions">
                        @* .StopPropagation evita que al dar clic al play se dispare también el clic del detalle *@
                        <button class="btn-play" @onclick:stopPropagation="true" @onclick="() => VerPelicula(35)"> ▶ </button>
                        <button class="btn-info" @onclick:stopPropagation="true" @onclick="() => IrAlDetalle(35)"> + </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <button class="nav-btn right" @onclick="() => Scroll(1)">&#10095;</button>
</div>

