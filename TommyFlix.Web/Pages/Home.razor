<style>
    /* Contenedor principal que recorta el contenido */
    .slider-viewport {
        position: relative;
        overflow: hidden;
        width: 100%;
        padding: 10px 0;
    }

    /* Tira de pósters */
    .posters-wrapper {
        display: flex;
        gap: 20px;
        transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
        will-change: transform;
    }

    /* Tarjeta individual con tamaño fijo para que el cálculo de C# funcione */
    .movie-card {
        flex: 0 0 200px; /* 200px de ancho fijo */
        height: 300px;
        border-radius: 8px;
        overflow: hidden;
        background: #1a1a1a;
    }

    /* Ajustes para Móvil (Media Query) */
    @@media (max-width: 600px) {
        .movie-card

    {
        flex: 0 0 160px; /* Tarjetas más pequeñas en móvil */
    }

    .nav-btn {
        padding: 10px;
        font-size: 1.2rem;
    }

    }

    /* Botones flotantes */
    .nav-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 100;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(5px);
        color: white;
        border: none;
        border-radius: 50%;
        width: 45px;
        height: 45px;
        cursor: pointer;
        transition: background 0.3s;
    }

        .nav-btn:hover {
            background: rgba(229, 9, 20, 0.9);
        }

        .nav-btn.left {
            left: 10px;
        }

        .nav-btn.right {
            right: 10px;
        }

</style>

<div class="posters-container" style="position: relative; overflow: hidden; width: 100%;">
    <div class="slider-viewport">

        @if (posicionX < 0)
        {
            <button class="nav-btn left" @onclick="() => MoverSlider(AnchoTarjeta * 2)">❮</button>
        }

        <div class="posters-wrapper" style="transform: translateX(@(posicionX)px);">
            @foreach (var movie in ListaDePeliculas)
            {
                <div class="movie-card">
                    <img src="@movie.PosterUrl" alt="@movie.Titulo" />
                    <div class="movie-info">@movie.Titulo</div>
                </div>
            }
        </div>

        @if (posicionX > LimiteDerecho)
        {
            <button class="nav-btn right" @onclick="() => MoverSlider(-(AnchoTarjeta * 2))">❯</button>
        }
    </div>
</div>


@code {
    private int posicionX = 0;

    // Configuración del slider (ajústalo a tu CSS)
    private const int AnchoTarjeta = 220; // 200px de imagen + 20px de gap
    // Detectamos cuántas tarjetas mostrar.
    // En móvil solemos ver 1 o 2, en PC 4 o 5.
    private int TarjetasVisibles => ListaDePeliculas.Count > 0 ? (posicionX == 0 ? 5 : 4) : 1;

    // Límite dinámico corregido
    private int LimiteDerecho => -((ListaDePeliculas.Count * AnchoTarjeta) - (AnchoTarjeta * 4));

    private void MoverSlider(int cantidad)
    {
        posicionX += cantidad;

        // Validaciones para no salir de los bordes
        if (posicionX > 0) posicionX = 0;
        if (posicionX < LimiteDerecho) posicionX = LimiteDerecho;
    }
}

