@page "/film/{filmID:int}"
@inject HttpClient Http

<PageTitle>Film</PageTitle>


@if (pelicula == null)
{
    <div class="loading-container">
        <div class="loader"></div>
        <p>Cargando detalles...</p>
    </div>
}
else
{
    <div class="detail-page" style="background-image: linear-gradient(to right, #141414 20%, transparent 80%), url('@pelicula.BackdropUrl');">
        <div class="detail-content">
            <h1 class="detail-title">@pelicula.Titulo</h1>

            <div class="detail-meta">
                <span class="match">98% para ti</span>
                <span class="year">@pelicula.Año</span>
                <span class="badge">@pelicula.Clasificacion</span>
                <span class="duration">2h 15min</span>
            </div>

            <p class="detail-description">
                @pelicula.Sinopsis
            </p>

            <div class="detail-actions">
                <a href="/reproducir/@pelicula.Id" class="btn-main-play">▶ Reproducir</a>
                <button class="btn-circle">+</button>
                <button class="btn-circle">👍</button>
            </div>

            <div class="detail-cast">
                <p><span>Elenco:</span> @pelicula.Elenco</p>
                <p><span>Géneros:</span> @pelicula.Generos</p>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int filmID { get; set; }
    private Pelicula? pelicula;

    protected override async Task OnInitializedAsync()
    {
        // Simulación de carga desde un servicio o API
        // pelicula = await PeliculaService.GetById(Id);

        // Ejemplo con datos locales para probar:
        await Task.Delay(500); // Simular red
        pelicula = new Pelicula
        {
            Id = filmID,
            Titulo = "Película Ejemplo " + filmID,
            Sinopsis = "Esta es una descripción épica de la película seleccionada...",
            BackdropUrl = "https://image.tmdb.org",
            Año = 2024,
            Clasificacion = "16+",
            Elenco = "Actor A, Actor B, Actor C",
            Generos = "Acción, Ciencia Ficción"
        };
    }

    public class Pelicula
    {
        public int Id { get; set; }
        public string Titulo { get; set; }
        public string Sinopsis { get; set; }
        public string BackdropUrl { get; set; }
        public int Año { get; set; }
        public string Clasificacion { get; set; }
        public string Elenco { get; set; }
        public string Generos { get; set; }
    }

}
