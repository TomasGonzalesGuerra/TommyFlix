@page "/movie/{Id:int}"
@inject NavigationManager _Nav
@inject TmdbService _TmdbService
@inject FavoriteService _FavoriteService
@inject AuthenticationStateProvider _AuthStateProvider

@if (movie == null)
{
    <div class="detail-loading">
        <p>Cargando...</p>
    </div>
}
else
{
    <div class="detail-hero" style="background-image: url('https://image.tmdb.org/t/p/original@(movie.Backdrop_Path)');">
        <div class="detail-hero-overlay">
            <div class="detail-hero-content">
                <img class="detail-poster" src="https://image.tmdb.org/t/p/w300@(movie.Poster_Path)" alt="@movie.Title" />
                <div class="detail-info">
                    <h1>@movie.Title</h1>
                    @if (!string.IsNullOrEmpty(movie.Tagline))
                    {
                        <p class="detail-tagline">"@movie.Tagline"</p>
                    }

                    <div class="detail-meta">
                        <span>⭐ @movie.Vote_Average.ToString("0.0")</span>
                        @if (movie.Runtime > 0)
                        {
                            <span>🕐 @($"{movie.Runtime / 60}h {movie.Runtime % 60}m")</span>
                        }
                        <span>📅 @movie.Release_Date?.Substring(0, 4)</span>
                    </div>

                    <div class="detail-genres">
                        @foreach (var genre in movie.Genres ?? [])
                        {
                            <span class="genre-tag">@genre.Name</span>
                        }
                    </div>

                    <p class="detail-overview">@movie.Overview</p>
                    
                    <div class="detail-buttons">
                        <button class="icon-btn play-btn" title="Reproducir trailer"
                                @onclick='() => _Nav.NavigateTo($"/watch/movie/{Id}")'>
                            <i class="bi bi-play-fill"></i>
                        </button>

                        <button class="icon-btn" title="@(isFavorite ? "Quitar de favoritos" : "Añadir a favoritos")"
                                @onclick="ToggleFavorite">
                            <i class="bi @(isFavorite ? "bi-heart-fill" : "bi-heart")"></i>
                        </button>

                        <button class="icon-btn" title="+ Mi Lista">
                            <i class="bi bi-clock"></i>
                        </button>

                        <button class="icon-btn" title="Me gusta">
                            <i class="bi bi-hand-thumbs-up"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (movie.Credits?.Cast?.Any() == true)
    {
        <div class="detail-section">
            <h2 class="section-title">Reparto</h2>
            <div class="cast-grid">
                @foreach (var actor in movie.Credits.Cast.Take(10))
                {
                    <div class="cast-card">
                        @if (!string.IsNullOrEmpty(actor.Profile_Path))
                        {
                            <img src="https://image.tmdb.org/t/p/w185@(actor.Profile_Path)" alt="@actor.Name" />
                        }
                        else
                        {
                            <div class="cast-no-photo">👤</div>
                        }
                        <p class="cast-name">@actor.Name</p>
                        <p class="cast-character">@actor.Character</p>
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter] public int Id { get; set; }
    private FrontMovie? movie;
    private bool isFavorite = false;
    private bool isLoggedIn = false;

    protected override async Task OnParametersSetAsync()
    {
        movie = null;
        movie = await _TmdbService.GetMovieDetails(Id);

        var authState = await _AuthStateProvider.GetAuthenticationStateAsync();
        isLoggedIn = authState.User.Identity?.IsAuthenticated ?? false;
        if (isLoggedIn) isFavorite = await _FavoriteService.IsMovieFavoriteAsync(Id);
    }

    private async Task ToggleFavorite()
    {
        var success = await _FavoriteService.ToggleMovieFavoriteAsync(Id, isFavorite);
        if (success) isFavorite = !isFavorite;
    }
}