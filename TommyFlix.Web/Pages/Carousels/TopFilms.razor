@inject HttpClient Http
@using System.Net.Http.Json
@using System.Text.Json.Serialization


@foreach (var movie in ListaDePeliculas)
{
    <div class="movie-card">
        <img src="@movie.FullPosterUrl" alt="@movie.Title" class="movie-poster" />
        <div class="movie-overlay">
            <h5 class="movie-title">@movie.Title</h5>
            <span class="movie-badge">⭐ @movie.Clasificacion.ToString("F1")</span>
            <!-- Tus botones de Ver e Info -->
        </div>
    </div>
}


@code {
    private List<MovieDto> ListaDePeliculas = new();
    private string apiKey = "c227b1a20bb851365272581db22b41fe"; // O usa el Token de acceso

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Ejemplo: Obtener películas populares
            var response = await Http.GetFromJsonAsync<TmdbResponse>($"movie/popular?api_key={apiKey}&language=es-ES&page=1");

            if (response?.Results != null)
            {
                ListaDePeliculas = response.Results;
                Console.WriteLine($"yA TA: {ListaDePeliculas.Count()}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar pelis: {ex.Message}");
        }
    }
}

@code {
    public class TmdbResponse
    {
        public List<MovieDto> Results { get; set; } = new();
    }

    public class MovieDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";

        // [JsonPropertyName("poster_path")]
        public string PosterPath { get; set; } = "";

        // [JsonPropertyName("vote_average")]
        public double Clasificacion { get; set; }

        // Propiedad calculada para la URL completa de la imagen
        public string FullPosterUrl => $"https://image.tmdb.org{PosterPath}";
    }
}

