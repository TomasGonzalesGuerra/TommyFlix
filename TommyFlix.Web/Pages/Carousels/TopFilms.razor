@code {
    public class MovieResponse
    {
        public int Page { get; set; }
        public List<Movie> Results { get; set; } = new();
    }

    public class Movie
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Overview { get; set; } = string.Empty;
