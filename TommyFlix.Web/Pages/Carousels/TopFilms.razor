
@using Microsoft.Extensions.Configuration
@using System.Net.Http.Headers
@inject IConfiguration Config
@using System.Net.Http.Json
@using System.Text.Json.Serialization
@inject HttpClient Http


<div class="mi-contenedor">
    <h1 class="mi-titulo">Películas Populares</h1>

    @if (peliculas == null)
    {
        <div class="cargando">Cargando películas desde TMDB...</div>
    }
    else
    {
        <div class="mi-rejilla">
            @foreach (var peli in peliculas.Results)
            {
                <div class="mi-tarjeta">
                    <img src="@($"https://tmdb.org{peli.PosterPath}")" alt="@peli.Title" class="mi-poster" />
                    <div class="mi-cuerpo">
                        <h2 class="mi-peli-titulo">@peli.Title</h2>
                        <p class="mi-peli-desc">@peli.Overview</p>
                        <div class="mi-peli-voto">⭐ @peli.VoteAverage</div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    /* CSS PURO */
    .mi-contenedor { font-family: sans-serif; padding: 20px; background-color: #0d253f; min-height: 100vh; color: white; }
    .mi-titulo { text-align: center; color: #01b4e4; margin-bottom: 30px; }

    .mi-rejilla {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 25px;
    }

    .mi-tarjeta {
        background: #1a3a5a;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        transition: transform 0.2s;
    }
    .mi-tarjeta:hover { transform: scale(1.03); }

    .mi-poster { width: 100%; height: auto; display: block; }

    .mi-cuerpo { padding: 15px; }
    .mi-peli-titulo { font-size: 1.1rem; margin: 0 0 10px 0; color: #fff; }
    .mi-peli-desc {
        font-size: 0.85rem;
        color: #ccc;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .mi-peli-voto { margin-top: 10px; font-weight: bold; color: #90cea1; }
    .cargando { text-align: center; font-size: 1.5rem; margin-top: 50px; }
</style>

@code {
    private TmdbResponse? peliculas;

    protected override async Task OnInitializedAsync()
    {
        // 1. Leemos los valores del JSON
        var baseUrl = Config["TmdbConfig:BaseUrl"];
        var token = Config["TmdbConfig:BearerToken"];
        var accountId = "9252834"; // Podrías sacarlo de config también


        // 2. Creamos la petición
        var request = new HttpRequestMessage(HttpMethod.Get, $"{baseUrl}/movie/popular");

        // 3. Añadimos el Header de forma limpia
        request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
        request.Headers.Accept.Add(new MediaTypeWithQualityHeaderValue("application/json"));

        var response = await Http.SendAsync(request);

        if (response.IsSuccessStatusCode)
        {
            // 4. PASAMOS EL JSON A LA CLASE C#
            peliculas = await response.Content.ReadFromJsonAsync<TmdbResponse>();
            Console.WriteLine(request);
        }
    }

    // CLASES PARA MAPEAR EL JSON (C# Puro)
    public class TmdbResponse
    {
        public List<Pelicula> Results { get; set; } = new();
    }

    public class Pelicula
    {
        [JsonPropertyName("title")]
        public string Title { get; set; }

        [JsonPropertyName("poster_path")] // Esto es CLAVE
        public string PosterPath { get; set; } = "";
        public string Overview { get; set; } = "";
        public double VoteAverage { get; set; }
    }
}









