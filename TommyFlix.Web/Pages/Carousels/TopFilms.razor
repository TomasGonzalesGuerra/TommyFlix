@page "/peliculas"
@using System.Net.Http.Json
@inject HttpClient Http

<h3>Películas Populares</h3>

@if (movies == null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="row">
        @foreach (var movie in movies)
        {
            <div class="col-md-3">
                <div class="card mb-4">
                    <img src="https://image.tmdb.org" class="card-img-top" alt="@movie.Title">
                    <div class="card-body">
                        <h5 class="card-title">@movie.Title</h5>
                        <p class="card-text text-truncate">@movie.Overview</p>
                    </div>
                </div>
            </div>
        }
    </div>
}

