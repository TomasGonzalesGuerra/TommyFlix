@inherits LayoutComponentBase

@Body

<style>
    /* Estructura para móviles (una sola columna) */
    main {
        display: grid;
        grid-template-columns: 1fr;
        grid-template-rows: auto 1fr auto;
    }

    /* Estructura para escritorio (Desktop) */
    @@media (min-width: 768px) {
        main {
            grid-template-columns: 250px 1fr; /* Sidebar fijo y contenido fluido */
            grid-template-rows: 1fr;
        }
    }
</style>