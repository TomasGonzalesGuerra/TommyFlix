@implements IDisposable


<div class="header-slider" @ref="sliderRef">
    <div class="slider-track" style="transform: translateX(-@(currentStep * 100)%)">
        <img src="https://static.posters.cz/image/hp/80594.jpg" alt="Slide 1" />
        <img src="https://moviepostermexico.com/cdn/shop/products/interstellar_ver7_xxlg_530x@2x.jpg?v=1571092081" alt="Slide 2" />
        <img src="https://static.posters.cz/image/hp/75998.jpg" alt="Slide 3" />
        <img src="https://pbs.twimg.com/media/D2jvOdmUgAALnnx.jpg" alt="Slide 4" />
    </div>
</div>

<h2 class="section-subtitle">Películas recomendadas</h2>

@code {
    private int currentStep = 0;
    private System.Timers.Timer? timer;
    private ElementReference sliderRef;

    protected override void OnInitialized()
    {
        timer = new System.Timers.Timer(5000); // 5 segundos
        timer.Elapsed += async (s, e) =>
        {
            currentStep = (currentStep + 1) % 3;
            await InvokeAsync(StateHasChanged);
        };
        timer.Start();
    }

    public void Dispose() => timer?.Dispose();
}
