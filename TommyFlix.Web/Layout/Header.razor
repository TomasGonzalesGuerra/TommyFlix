@implements IDisposable

<NavMenu/>

<div class="header-slider" @ref="sliderRef">
    <div class="slider-track" style="transform: translateX(-@(currentStep * 100)%)">
        <img src="img1.jpg" alt="Slide 1" />
        <img src="img2.jpg" alt="Slide 2" />
        <img src="img3.jpg" alt="Slide 3" />
    </div>
</div>

<h2 class="section-subtitle">Películas recomendadas</h2>

@code {
    private int currentStep = 0;
    private System.Timers.Timer? timer;
    private ElementReference sliderRef;

    protected override void OnInitialized()
    {
        timer = new System.Timers.Timer(5000); // 5 segundos
        timer.Elapsed += async (s, e) =>
        {
            currentStep = (currentStep + 1) % 3;
            await InvokeAsync(StateHasChanged);
        };
        timer.Start();
    }

    public void Dispose() => timer?.Dispose();
}
