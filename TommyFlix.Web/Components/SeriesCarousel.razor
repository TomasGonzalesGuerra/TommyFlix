@inject TmdbService TmdbService

<MovieDetailModal Movie="@selectedSerieAsMovie" IsVisible="isModalVisible" OnClose="CloseModal" />

<div class="carousel-wrapper">
    <button class="nav left" @onclick="Prev">❮</button>

    <div class="carousel-viewport">
        <div class="carousel-track" style="transform: translateX(-@(currentIndex* itemWidth)px)">
            @if (series == null)
            {                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   
                <p>Cargando...</p>
            }
            else
            {
                @foreach (var item in series)
                {
                    <div class="movie-card" @onclick="() => OpenModal(item.Id)">
                        <img src="@($"https://image.tmdb.org/t/p/w500{item.Poster_Path}")" />

                        <div class="overlay">
                            <h4>@item.Name</h4>
                            <p>⭐ @item.Vote_Average</p>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <button class="nav right" @onclick="Next">❯</button>
</div>

@code {
    private List<TvSeries> series =[];

    protected override async Task OnInitializedAsync()
    {
        var response = await TmdbService.GetPopularSeries();
        series = response.Results;
    }
}

@code {
    private int currentIndex = 0;
    private int itemWidth = 200; // ancho + gap aprox

    private void Next()
    {
        if (series == null) return;
        if (currentIndex < series.Count - 5) currentIndex++;
    }

    private void Prev()
    {
        if (currentIndex > 0) currentIndex--;
    }
}

@code {
    private TvSeries selectedSerie = new();
    private Movie selectedSerieAsMovie = new();
    private bool isModalVisible = false;

    private async Task OpenModal(int id)
    {
        selectedSerie = await TmdbService.GetSerieDetails(id);

        selectedSerieAsMovie = new()
        {
            Title = selectedSerie.Name,
            Overview = selectedSerie.Overview,
            Release_Date = selectedSerie.Release_Date,
            Vote_Average = selectedSerie.Vote_Average,
            Poster_Path = selectedSerie.Poster_Path,
            Backdrop_Path = selectedSerie.Backdrop_Path,
        };

        isModalVisible = true;
    }

    private Task CloseModal()
    {
        isModalVisible = false;
        selectedSerie = null!;
        selectedSerieAsMovie = null!;
        return Task.CompletedTask;
    }
}